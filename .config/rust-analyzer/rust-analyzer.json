{
  "check": {
    "command": "clippy",
    "extraArgs": [
      "--",
      "--force-warn",
      "clippy::pedantic",
      "-Dwarnings"
    ]
  },
  "diagnostics": {
    "styleLints": {
      "enable": true
    }
  },
  "semanticHighlighting": {
    "punctuation": {
      "enable": true,
      "specialization": {
        "enable": true
      },
      "separate": {
        "macro": {
          "bang": true
        }
      }
    },
    "operator": {
      "specialization": {
        "enable": true
      }
    }
  },
  "inlayHints": {
    "closureStyle": "rust_analyzer",
    "typeHints": {
      "hideNamedConstructor": true,
      "hideClosureInitialization": true
    },
    "expressionAdjustmentHints": {
      "enable": "reborrow"
    },
    "closureCaptureHints": {
      "enable": true
    }
  },
  "lens": {
    "references": {
      "adt": {
        "enable": true
      },
      "enumVariant": {
        "enable": true
      },
      "method": {
        "enable": true
      },
      "trait": {
        "enable": true
      }
    }
  }
}
